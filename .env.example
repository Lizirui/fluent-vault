# RPC / 网络
SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_PROJECT_ID"
ETHERSCAN_API_KEY="your-etherscan-api-key"

# Faucet / Relayer 私钥（仅用于测试环境，勿在生产环境直接使用）
FAUCET_PRIVATE_KEY="0xabc123...your_test_private_key"

# 已部署合约地址（用于后端 viem 调用）
MOCK_USDC_ADDRESS="0xYourMockUsdcOnSepolia"
ORDER_BOOK_ADDRESS="0xYourOrderBookOnSepolia"
FLUENT_VAULT_ADDRESS="0xYourFluentVaultOnSepolia"

# 前端公开配置
NEXT_PUBLIC_CHAIN_ID="11155111" # Sepolia
NEXT_PUBLIC_RPC_URL="${SEPOLIA_RPC_URL}"
NEXT_PUBLIC_MOCK_USDC_ADDRESS="${MOCK_USDC_ADDRESS}"
NEXT_PUBLIC_VAULT_ADDRESS="${FLUENT_VAULT_ADDRESS}"
NEXT_PUBLIC_ORDER_BOOK_ADDRESS="${ORDER_BOOK_ADDRESS}"

# Upstash Redis（用于限流）
UPSTASH_REDIS_REST_URL="https://your-upstash-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# 可选：持久化订单存储（如 Supabase）
SUPABASE_URL="https://your-supabase-url"
SUPABASE_ANON_KEY="your-supabase-anon-key"

