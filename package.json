    "lint": "cd packages/frontend && next lint"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "typescript": "^5.6.3"
  }
}

